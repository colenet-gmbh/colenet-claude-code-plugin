# Claude Code local, per-project plugin settings (not for version control)
.claude/*.local.md
.claude/settings.local.json

# cape no longer vendors skills — they load from the plugin as cape:<name>. This repo IS
# the source (skills_source/), so a stray .claude/skills/ snapshot from an old cape would
# only duplicate it. Ignored so such a snapshot never gets committed here.
.claude/skills/

# Ephemeral fixtures generated by the convention eval harness (evals/conventions/). Each
# run scaffolds a throwaway two-tier repo here (only when --keep is passed; otherwise it
# lives in an OS tmpdir). Never committed.
evals/conventions/.workdir/

# OS / editor noise
.DS_Store
Thumbs.db
*.swp
.idea/
.vscode/
